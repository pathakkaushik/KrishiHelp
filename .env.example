# ─── KrishiMitra AI — Environment Configuration ──────────────
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ─── Database ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=KrishiRoot@2024
MYSQL_PASSWORD=KrishiDB@2024

# ─── Security ────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=KrishiMitraSecretKey2024VeryLongAndSecureKeyForJWTTokenGenerationChangeInProduction

# ─── AI Integration ──────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Weather API ─────────────────────────────────────────────
# Get from https://openweathermap.org/api
WEATHER_API_KEY=your-openweather-api-key

# ─── Email (Gmail SMTP) ──────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your-app-password

# ─── AWS S3 (File Storage) ───────────────────────────────────
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET=krishimitra-uploads

# ─── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api


